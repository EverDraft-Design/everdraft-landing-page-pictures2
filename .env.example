# EverDraft Supabase foundation settings.
# This Cloudflare Worker reads environment variables server-side, so no
# frontend-specific public prefix is needed for this project.

SUPABASE_URL=
SUPABASE_ANON_KEY=

# Optional local-only flag for the temporary developer check endpoint:
# /api/dev/supabase-check
ENABLE_SUPABASE_DEV_CHECK=false

# The Supabase anon/public key is safe to use in public clients when Row Level
# Security is configured correctly. Never expose or commit a Supabase service
# role key in frontend code, static assets, or public environment variables.
